# ========== 数据库（必填）==========
# 与 docker-compose.yml 默认一致时可照抄；自建库则改用户/库名
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/astraus_dev"

# ========== NextAuth（必填）==========
# 随机长字符串，用于 JWT 加密
NEXTAUTH_SECRET="请替换为至少32字节的随机字符串"
# 本机开发示例；多端口见 package.json 中各 dev 脚本
NEXTAUTH_URL="http://localhost:3000"
# 若代码里仍有读取 JWT_SECRET，可与 NEXTAUTH_SECRET 设为相同
JWT_SECRET="与_NEXTAUTH_SECRET_相同即可"

# ========== 站点 URL（可选，用于绝对链接）==========
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ========== 管理后台（Astraus，路径 /admin）==========
# 登录 /admin/login 的密码；生产务必改掉
ADMIN_PASSWORD="123456789"
# 可选；不设则回退为 NEXTAUTH_SECRET，用于后台 Cookie 签名
# ADMIN_SECRET=""

# ========== 存储 ==========
# false：图片在 public/uploads，头像在 public/avatars
USE_BLOB_STORAGE="false"
NEXT_PUBLIC_USE_BLOB_STORAGE="false"
# true 时填写 Vercel Blob
# BLOB_READ_WRITE_TOKEN=""
# BLOB_BASE_URL=""
